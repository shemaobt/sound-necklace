      "pcm": { "seed": 222, "sampleRate": 8000, "samples": 96000, "channels": 1 }
    },
    { "type": "confirmWhole" },
    { "type": "cutScene", "endBead": 23 },
    { "type": "confirmParts" },
    { "type": "triage", "partIndex": 0, "kind": "GLEANING_SCENE", "confidence": "alta" },
    { "type": "triagemDone" },
    { "type": "phraseSelect", "s": 0, "e": 5 },
    { "type": "confirmPhrase" },
    { "type": "sceneDone" },
    { "type": "answer", "level": 1, "key": "recontar", "text": "Resposta inicial da história." },
    {
      "type": "answer",
      "level": 2,
      "partId": "PT1",
      "key": "descrever",
      "text": "Resposta inicial da cena."
    },
    {
      "type": "answer",
      "level": 3,
      "propId": "P1",
      "key": "oque",
      "text": "Resposta antiga da P1 — deve sobreviver."
    },
    { "type": "reopenPhrase", "index": 0 },
    { "type": "phraseSelect", "s": 0, "e": 9 },
    { "type": "confirmPhrase" },
    { "type": "phraseSelect", "s": 10, "e": 15 },
    { "type": "confirmPhrase" },
    { "type": "sceneDone" },
    { "type": "answer", "level": 3, "propId": "P2", "key": "oque", "text": "Resposta nova da P2." },
    { "type": "export", "artifacts": ["manifesto", "retorno", "relatorio"] }
  ]
}
