{
  "name": "mapping-lazy",
  "description": "Respostas preenchidas, depois frase reaberta + re-cortada + nova frase: as respostas antigas (por prop_id) são preservadas e as novas chaves são semeadas; o relatório reflete ambas.",
  "steps": [
    {
      "type": "segment",
      "beadSec": 0.5,
      "slug": "mapeamento-preguicoso",
