      "pcm": { "seed": 202, "sampleRate": 8000, "samples": 96000, "channels": 1 }
    },
    { "type": "confirmWhole" },
    { "type": "cutScene", "endBead": 23 },
    { "type": "confirmParts" },
    { "type": "triage", "partIndex": 0, "kind": "GLEANING_SCENE", "confidence": "high" },
    { "type": "triagemDone" },
    { "type": "phraseSelect", "s": 0, "e": 3 },
    { "type": "confirmPhrase" },
    { "type": "phraseSelect", "s": 4, "e": 7 },
    { "type": "confirmPhrase" },
    { "type": "phraseSelect", "s": 8, "e": 11 },
    { "type": "confirmPhrase" },
    { "type": "removePhrase", "index": 1 },
    { "type": "phraseSelect", "s": 12, "e": 15 },
    { "type": "confirmPhrase" },
    { "type": "phraseSelect", "s": 16, "e": 19 },
    { "type": "confirmPhrase" },
    { "type": "sceneDone" },
    { "type": "export", "artifacts": ["manifesto", "retorno"] }
  ]
}
