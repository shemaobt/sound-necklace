# Configuração de ambiente do SPA (ENG-247). Copie para .env.local e ajuste.
# SEM nada disto, o app roda 100% em fixture — o default de teste/CI.

# Liga os adapters reais contra o tripod-api. Por ora governa AUTH (login real por
# e-mail da conta tripod + papéis via my-roles) e a base do TTS (voz ElevenLabs).
# Sessões/bucket/áudio seguem fixture até o restante da ENG-247.
# VITE_API_MODE=real

# Base da API real, com o prefixo /api. Produção compartilhada (Cloud Run):
# VITE_API_BASE_URL=https://tripod-backend-f7ssqjozfq-uc.a.run.app/api

# Gravador da entrevista: real (microfone) é o default — a fixture só serve a
# harnesses sem microfone, como jsdom (ENG-298).
# VITE_VOICE=fixture
